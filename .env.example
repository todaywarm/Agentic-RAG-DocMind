# Environment Variables Template
# Copy this file to .env and fill in your API keys

# ========== LLM Configuration (Required) ==========
LLM_API_KEY=your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_ID=deepseek-chat

# ========== RAG API Configuration (Optional) ==========
# If set, will use remote API for Embedding and Reranker (faster, no local model download)
# Get free API key at: https://cloud.siliconflow.cn/
RAG_API_KEY=your_siliconflow_api_key_here

# Alternative key name (also works)
# SILICONFLOW_API_KEY=your_siliconflow_api_key_here
